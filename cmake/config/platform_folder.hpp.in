#pragma once

#include <filesystem>
#include <string_view>

namespace incom::terminal_plot::platform_folders {
namespace fs = std::filesystem;

inline constexpr std::string_view project_name = "@INCPLOT_PROJECT_NAME@";

// Install prefix and canonical install directories resolved by CMake at configure time.
inline const fs::path install_prefix = "@INCPLOT_INSTALL_PREFIX@";
inline const fs::path install_bindir = "@INCPLOT_INSTALL_BINDIR@";
inline const fs::path install_libdir = "@INCPLOT_INSTALL_LIBDIR@";
inline const fs::path install_datadir = "@INCPLOT_INSTALL_DATADIR@";
inline const fs::path install_sysconfdir = "@INCPLOT_INSTALL_SYSCONFDIR@";
inline const fs::path install_localstatedir = "@INCPLOT_INSTALL_LOCALSTATEDIR@";
inline const fs::path install_runstatedir = "@INCPLOT_INSTALL_RUNSTATEDIR@";

// Relative install directories (from prefix). Useful for relocatable layouts.
inline const fs::path rel_bindir = "@INCPLOT_REL_BINDIR@";
inline const fs::path rel_libdir = "@INCPLOT_REL_LIBDIR@";
inline const fs::path rel_datadir = "@INCPLOT_REL_DATADIR@";
inline const fs::path rel_sysconfdir = "@INCPLOT_REL_SYSCONFDIR@";
inline const fs::path rel_localstatedir = "@INCPLOT_REL_LOCALSTATEDIR@";
inline const fs::path rel_runstatedir = "@INCPLOT_REL_RUNSTATEDIR@";

// Project-scoped defaults under standard install roots.
inline const fs::path app_data_dir = "@INCPLOT_APP_DATA_DIR@";
inline const fs::path app_config_dir = "@INCPLOT_APP_CONFIG_DIR@";

} // namespace incom::terminal_plot::platform_folders
